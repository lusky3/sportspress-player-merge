includes:
  - %rootDir%/../../szepeviktor/phpstan-wordpress/extension.neon

parameters:
  level: 5
  paths:
    - sportspress-player-merge.php
    - classes/
    - includes/
    - uninstall.php
  bootstrapFiles:
    - phpstan-bootstrap.php
  reportUnmatchedIgnoredErrors: false
  ignoreErrors:
    - '#Function apply_filters invoked with#'
    - '#Function do_action invoked with#'
    - '#will always evaluate to false#'
    - '#result will always#'
