#!/bin/sh
# Pre-commit hook for WordPress plugin repos
# Checks staged files for secrets, syntax errors, debug code, and AI hallucinations

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_PHP=$(echo "$STAGED" | grep '\.php$' || true)

[ -z "$STAGED" ] && exit 0

# 1. Merge conflict markers
if echo "$STAGED" | xargs grep -lE '^(<{7}|={7}|>{7})' 2>/dev/null; then
  echo "❌ Merge conflict markers found in staged files"
  exit 1
fi

# 2. Secret scanning via gitleaks
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --pre-commit --staged --no-banner
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Secrets detected by gitleaks. Remove them before committing."
    echo "   To skip (NOT recommended): git commit --no-verify"
    exit 1
  fi
else
  # Fallback: basic regex patterns if gitleaks not installed
  SECRETS_PATTERN='(AKIA[0-9A-Z]{16}|sk_live_[0-9a-zA-Z]{24,}|ghp_[0-9a-zA-Z]{36}|glpat-[0-9a-zA-Z\-_]{20,}|xox[baprs]-[0-9a-zA-Z\-]{10,}|-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----|sk-[0-9a-zA-Z]{20,})'
  MATCHES=$(echo "$STAGED" | xargs grep -lE "$SECRETS_PATTERN" 2>/dev/null | grep -v '\.sample$' | grep -v 'SECURITY\.md' || true)
  if [ -n "$MATCHES" ]; then
    echo "❌ Possible secrets detected (install gitleaks for better detection):"
    echo "$MATCHES"
    exit 1
  fi
fi

[ -z "$STAGED_PHP" ] && exit 0

# 3. PHP syntax check
echo "$STAGED_PHP" | while IFS= read -r file; do
  [ -z "$file" ] && continue
  OUTPUT=$(php -l "$file" 2>&1)
  if [ $? -ne 0 ]; then
    echo "❌ PHP syntax error:"
    echo "$OUTPUT"
    exit 1
  fi
done || exit 1

# 4. Debug statements
DEBUG_MATCHES=$(echo "$STAGED_PHP" | xargs grep -nE '\b(var_dump|print_r|error_log|var_export)\s*\(' 2>/dev/null || true)
if [ -n "$DEBUG_MATCHES" ]; then
  echo "❌ Debug statements found in staged files:"
  echo "$DEBUG_MATCHES"
  exit 1
fi

# 5. Hallucinated PHP classes (advisory)
echo "$STAGED_PHP" | while IFS= read -r file; do
  [ -z "$file" ] && continue
  USES=$(grep -oP '^use\s+\K[A-Z][A-Za-z0-9\\]+(?=;)' "$file" 2>/dev/null | grep -v '^WP_' | grep -v '^wpdb' || true)
  for class in $USES; do
    BASE=$(echo "$class" | sed 's/.*\\//')
    if ! grep -rql "class $BASE\b" --include='*.php' . 2>/dev/null; then
      if [ -d vendor ] && ! grep -rql "class $BASE\b" --include='*.php' vendor/ 2>/dev/null; then
        echo "⚠️  Possibly hallucinated class '$class' in $file"
      fi
    fi
  done
done

exit 0
